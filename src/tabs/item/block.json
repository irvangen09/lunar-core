{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "lunar-core/tabs-item",
	"title": "Lunar Tab Item",
	"category": "lunar-blocks",
	"description": "Satu tab di dalam Tabs — label singkat dan konten bebas (paragraf, gambar, link, block lain).",
	"parent": [ "lunar-core/tabs" ],
	"textdomain": "lunar-core",
	"attributes": {
		"label": {
			"type": "rich-text",
			"source": "rich-text",
			"selector": ".lunar-tabs-item__label"
		}
	},
	"supports": {
		"html": false,
		"reusable": false
	}
}
