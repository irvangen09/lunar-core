{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "lunar-core/definition-item",
	"title": "Lunar Definition Item",
	"category": "lunar-blocks",
	"description": "Satu pasang istilah dan definisi di dalam Definition List.",
	"parent": [ "lunar-core/definition-list" ],
	"textdomain": "lunar-core",
	"attributes": {
		"term": {
			"type": "rich-text",
			"source": "rich-text",
			"selector": ".lunar-definition-item__term"
		},
		"definition": {
			"type": "rich-text",
			"source": "rich-text",
			"selector": ".lunar-definition-item__definition"
		}
	},
	"supports": {
		"html": false,
		"reusable": false
	}
}
