{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "lunar-core/callout",
	"title": "Lunar Callout",
	"category": "lunar-blocks",
	"description": "Menonjolkan potongan informasi penting (tips, catatan, peringatan) di tengah artikel.",
	"keywords": [ "callout", "catatan", "tips", "peringatan" ],
	"textdomain": "lunar-core",
	"attributes": {
		"variant": {
			"type": "string",
			"enum": [ "info", "tips", "peringatan", "penting" ],
			"default": "info"
		},
		"content": {
			"type": "rich-text",
			"source": "rich-text",
			"selector": ".lunar-callout__text"
		}
	},
	"supports": {
		"html": false,
		"anchor": true
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css"
}
